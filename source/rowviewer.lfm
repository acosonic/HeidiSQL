object RowViewerForm: TRowViewerForm
  Left = 0
  Height = 460
  Top = 0
  Width = 500
  Caption = 'Row Viewer'
  ClientHeight = 460
  ClientWidth = 500
  Position = poOwnerFormCenter
  LCLVersion = '4.4.0.0'
  OnClose = FormClose
  OnCreate = FormCreate
  OnKeyDown = FormKeyDown
  KeyPreview = True
  object GridViewer: TStringGrid
    Left = 0
    Height = 420
    Top = 0
    Width = 500
    Align = alClient
    ColCount = 2
    DefaultRowHeight = 22
    FixedCols = 0
    FixedRows = 1
    Options = [goFixedVertLine, goFixedHorzLine, goVertLine, goHorzLine, goRowSizing, goThumbTracking, goRowSelect]
    RowCount = 2
    TabOrder = 0
    OnDrawCell = GridViewerDrawCell
  end
  object pnlBottom: TPanel
    Left = 0
    Height = 40
    Top = 420
    Width = 500
    Align = alBottom
    BevelOuter = bvNone
    object btnPrev: TButton
      Left = 4
      Height = 30
      Top = 5
      Width = 70
      Caption = '◄ Prev'
      OnClick = btnPrevClick
    end
    object lblRow: TLabel
      Left = 80
      Height = 30
      Top = 5
      Width = 260
      Alignment = taCenter
      Layout = tlCenter
    end
    object btnNext: TButton
      Left = 346
      Height = 30
      Top = 5
      Width = 70
      Caption = 'Next ►'
      OnClick = btnNextClick
    end
    object btnClose: TButton
      Left = 422
      Height = 30
      Top = 5
      Width = 70
      Caption = 'Close'
      OnClick = btnCloseClick
    end
  end
end
